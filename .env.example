# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=pse2025
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432
# ─── Mosquitto MQTT ───────────────────────────────────────────────────────────
# Host port mapped to the MQTT TCP listener
MQTT_PORT=1883
# Host port mapped to the MQTT WebSocket listener
MQTT_WS_PORT=9001
# Hostname the backend uses to reach the broker.
# Use "mosquitto" inside Docker (set automatically by docker-compose.yml).
# Use "localhost" when running the backend outside Docker.
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9002
MINIO_USE_SSL=false

# ─── Application ports ────────────────────────────────────────────────────────
BACKEND_PORT=4000
FRONTEND_PORT=3000
